        "liquid_qCjND6": {
          "type": "liquid",
          "settings": {
            "liquid": "<style>\n  .stock-alert {\n    display: inline-flex;\n    align-items: center;\n    gap: 8px;\n    font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;\n    font-size: 15px;\n    font-weight: 700;\n    color: #e60000;\n    line-height: 1.2;\n  }\n\n  .stock-alert .dot {\n    position: relative;\n    width: 10px;\n    height: 10px;\n    border-radius: 50%;\n    background: #e60000;\n    display: inline-block;\n  }\n\n  .stock-alert .dot::after {\n    content: \"\";\n    position: absolute;\n    inset: -5px;\n    border-radius: 50%;\n    border: 2px solid #e60000;\n    opacity: 0;\n    animation: pulse-ring 1.5s ease-out infinite;\n  }\n\n  @keyframes pulse-ring {\n    0%   { transform: scale(0.7); opacity: 0.9; }\n    60%  { transform: scale(1.25); opacity: 0.25; }\n    100% { transform: scale(1.45); opacity: 0; }\n  }\n</style>\n\n<div class=\"stock-alert\" id=\"stock-alert\">\n  <span class=\"dot\" aria-hidden=\"true\"></span>\n  <span id=\"stock-text\">Stock limité: 6 unités restante!</span>\n</div>\n\n<script>\ndocument.addEventListener(\"DOMContentLoaded\", function() {\n  const stockSection = document.getElementById(\"stock-alert\");\n  const stockText = document.getElementById(\"stock-text\");\n\n  // Verifica se l'effetto è già avvenuto\n  const alreadyReduced = localStorage.getItem(\"lanoxie_stock_reduced\");\n\n  if (!alreadyReduced && stockSection) {\n    const observer = new IntersectionObserver((entries) => {\n      entries.forEach(entry => {\n        if (entry.isIntersecting) {\n          // Anima la transizione da 17 a 12\n          let start = 17;\n          const end = 12;\n          const duration = 1500; // in ms\n          const steps = start - end;\n          const interval = duration / steps;\n          \n          const timer = setInterval(() => {\n            start--;\n            stockText.textContent = `Stock disponibile: ${start} pezzi rimasti!`;\n            if (start <= end) {\n              clearInterval(timer);\n              localStorage.setItem(\"lanoxie_stock_reduced\", \"true\");\n            }\n          }, interval);\n\n          observer.disconnect();\n        }\n      });\n    }, { threshold: 0.6 }); // si attiva quando ~60% della sezione è visibile\n\n    observer.observe(stockSection);\n  } else if (alreadyReduced && stockText) {\n    // Se già visto, mantiene il testo a 12\n    stockText.textContent = \"Stock limité: 6 unités restantes!\";\n  }\n});\n</script>"
          }
        },
