            "liquid": "<style>\n  .vitaora-reviews {\n    font-family: Inter, sans-serif;\n    position: relative;\n    overflow: hidden;\n    margin: 16px 0;\n  }\n  .vitaora-reviews-track {\n    display: flex;\n    transition: transform 0.4s ease;\n  }\n  .vitaora-review-card {\n    min-width: 100%;\n    border: 1px solid #E0E0E0;\n    border-radius: 12px;\n    padding: 16px;\n    background: #fff;\n    box-sizing: border-box;\n  }\n  .vitaora-review-top {\n    display: flex;\n    justify-content: space-between;\n    align-items: flex-start;\n    margin-bottom: 12px;\n  }\n  .vitaora-stars {\n    color: #F5A623;\n    font-size: 16px;\n    letter-spacing: 2px;\n  }\n  .vitaora-reviewer {\n    font-size: 12px;\n    font-weight: 700;\n    color: #1A1A1A;\n    text-align: right;\n    line-height: 1.4;\n  }\n  .vitaora-review-text {\n    font-size: 12px;\n    color: #1A1A1A;\n    line-height: 1.6;\n    margin-bottom: 12px;\n  }\n  .vitaora-verified {\n    display: flex;\n    align-items: center;\n    gap: 6px;\n    font-size: 12px;\n    color: #057664;\n    font-weight: 500;\n  }\n  .vitaora-verified svg {\n    flex-shrink: 0;\n  }\n  .vitaora-dots {\n    display: flex;\n    justify-content: center;\n    gap: 6px;\n    margin-top: 12px;\n  }\n  .vitaora-dot {\n    width: 7px;\n    height: 7px;\n    border-radius: 50%;\n    background: #D0D0D0;\n    cursor: pointer;\n    border: none;\n    padding: 0;\n  }\n  .vitaora-dot.active {\n    background: #1A1A1A;\n  }\n</style>\n\n<div class=\"vitaora-reviews\">\n  <div class=\"vitaora-reviews-track\" id=\"vitaoraTrack\">\n\n    <!-- Avis 1 -->\n    <div class=\"vitaora-review-card\">\n      <div class=\"vitaora-review-top\">\n        <div class=\"vitaora-stars\">★★★★★</div>\n        <div class=\"vitaora-reviewer\">Marie, 41 ans | Pré-<br>ménopause</div>\n      </div>\n      <div class=\"vitaora-review-text\">\n        \"En 7 jours, ma bague <strong>ne me serrait plus</strong> le matin et mon <strong>visage était moins bouffi</strong>. Les jambes <strong>sont plus légères</strong> le soir et plus besoin de courir aux toilettes toutes les 10min. Je me sens enfin <strong>à l'aise dans mes vêtements</strong>.\"\n      </div>\n      <div class=\"vitaora-verified\">\n        <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n          <circle cx=\"8\" cy=\"8\" r=\"8\" fill=\"#057664\"/>\n          <path d=\"M4.5 8L7 10.5L11.5 6\" stroke=\"white\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n        </svg>\n        Acheteur vérifié\n      </div>\n    </div>\n\n    <!-- Avis 2 -->\n    <div class=\"vitaora-review-card\">\n      <div class=\"vitaora-review-top\">\n        <div class=\"vitaora-stars\">★★★★★</div>\n        <div class=\"vitaora-reviewer\">Clara, 41 ans | Retour de<br>grossesse</div>\n      </div>\n      <div class=\"vitaora-review-text\">\n        Finies les marques de chaussettes après la journée au bureau ! <strong>Ventre moins tendu, chevilles plus fines</strong>, et <strong>zéro effet diurétique</strong>. C'est la première fois que je vois une <strong>différence aussi vite</strong>.\n      </div>\n      <div class=\"vitaora-verified\">\n        <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n          <circle cx=\"8\" cy=\"8\" r=\"8\" fill=\"#057664\"/>\n          <path d=\"M4.5 8L7 10.5L11.5 6\" stroke=\"white\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n        </svg>\n        Acheteur vérifié\n      </div>\n    </div>\n\n    <!-- Avis 3 -->\n    <div class=\"vitaora-review-card\">\n      <div class=\"vitaora-review-top\">\n        <div class=\"vitaora-stars\">★★★★★</div>\n        <div class=\"vitaora-reviewer\">Isabelle, 54 ans | 1ère<br>utilisation</div>\n      </div>\n      <div class=\"vitaora-review-text\">\n        \"Mon jean ferme <strong>sans bataille</strong> depuis la 2e semaine et je me réveille avec le visage plus frais. <strong>Sensation de légèreté retrouvée et durable</strong> pour une fois !\"\n      </div>\n      <div class=\"vitaora-verified\">\n        <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n          <circle cx=\"8\" cy=\"8\" r=\"8\" fill=\"#057664\"/>\n          <path d=\"M4.5 8L7 10.5L11.5 6\" stroke=\"white\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n        </svg>\n        Acheteur vérifié\n      </div>\n    </div>\n\n  </div>\n\n  <!-- Dots -->\n  <div class=\"vitaora-dots\">\n    <button class=\"vitaora-dot active\" onclick=\"vitaoraGoTo(0)\"></button>\n    <button class=\"vitaora-dot\" onclick=\"vitaoraGoTo(1)\"></button>\n    <button class=\"vitaora-dot\" onclick=\"vitaoraGoTo(2)\"></button>\n  </div>\n</div>\n\n<script>\n  let vitaoraCurrentSlide = 0;\n  const vitaoraTotal = 3;\n\n  function vitaoraGoTo(index) {\n    vitaoraCurrentSlide = index;\n    const track = document.getElementById('vitaoraTrack');\n    track.style.transform = `translateX(-${index * 100}%)`;\n    document.querySelectorAll('.vitaora-dot').forEach((d, i) => {\n      d.classList.toggle('active', i === index);\n    });\n  }\n\n  // Swipe touch\n  let vitaoraTouchStartX = 0;\n  const vitaoraTrackEl = document.getElementById('vitaoraTrack');\n\n  vitaoraTrackEl.addEventListener('touchstart', e => {\n    vitaoraTouchStartX = e.touches[0].clientX;\n  });\n\n  vitaoraTrackEl.addEventListener('touchend', e => {\n    const diff = vitaoraTouchStartX - e.changedTouches[0].clientX;\n    if (diff > 40 && vitaoraCurrentSlide < vitaoraTotal - 1) vitaoraGoTo(vitaoraCurrentSlide + 1);\n    if (diff < -40 && vitaoraCurrentSlide > 0) vitaoraGoTo(vitaoraCurrentSlide - 1);\n  });\n</script>"
          }
        }
