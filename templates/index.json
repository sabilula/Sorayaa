-container\">\n        <video class=\"grid-video\" autoplay muted loop playsinline onclick=\"togglePlayPause(this)\">\n          <source src=\"https://cdn.shopify.com/videos/c/o/v/0db1bcc3837142a09beaca5680d1ada7.mov\" type=\"video/mp4\">\n        </video>\n      </div>\n    </div>\n    <button class=\"carousel-nav next\" onclick=\"moveCarousel(1)\">\n      <svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n        <path d=\"M9 5L16 12L9 19\" stroke=\"black\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n      </svg>\n    </button>\n  </div>\n  <div class=\"carousel-dots\" id=\"carouselDots\"></div>\n</div>\n\n<style>\n  .video-carousel-wrapper {\n    max-width: 900px;\n    margin: auto;\n  }\n\n  .video-carousel-container {\n    position: relative;\n    display: flex;\n    align-items: center;\n  }\n\n  .video-grid {\n    display: flex;\n    gap: 20px;\n    width: 900px;\n    overflow: hidden;\n  }\n\n  .video-container {\n    flex: 0 0 auto;\n  }\n\n  .grid-video {\n    width: 280px;\n    height: 320px;\n    object-fit: cover;\n    border-radius: 8px;\n    cursor: pointer;\n  }\n\n  .carousel-nav {\n    background-color: rgba(255, 255, 255, 0.9);\n    border: none;\n    border-radius: 50%;\n    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);\n    cursor: pointer;\n    position: absolute;\n    top: 50%;\n    transform: translateY(-50%);\n    z-index: 2;\n    padding: 10px;\n    transition: background 0.2s;\n  }\n\n  .carousel-nav:hover { background-color: #fff; }\n  .carousel-nav.prev { left: -20px; }\n  .carousel-nav.next { right: -20px; }\n\n  .carousel-dots {\n    display: flex;\n    justify-content: center;\n    gap: 8px;\n    margin-top: 16px;\n  }\n\n  .carousel-dot {\n    width: 8px;\n    height: 8px;\n    border-radius: 50%;\n    background: #ddd;\n    cursor: pointer;\n    transition: background 0.3s;\n    border: none;\n    padding: 0;\n  }\n\n  .carousel-dot.active {\n    background: #C9A84C;\n    transform: scale(1.2);\n  }\n\n  @media (max-width: 768px) {\n    .video-grid {\n      gap: 10px;\n      width: 100%;\n      overflow-x: scroll;\n      scroll-snap-type: x mandatory;\n      -webkit-overflow-scrolling: touch;\n    }\n\n    .video-container { scroll-snap-align: start; }\n\n    .grid-video {\n      width: 45vw;\n      height: 80vw;\n    }\n\n    .carousel-nav { display: none; }\n  }\n</style>\n\n<script>\n  const totalVideos = 6;\n  const videosPerView = 3;\n  let currentIndex = 0;\n\n  function generateDots() {\n    const dotsContainer = document.getElementById('carouselDots');\n    const totalDots = Math.ceil(totalVideos / videosPerView);\n    dotsContainer.innerHTML = '';\n    for (let i = 0; i < totalDots; i++) {\n      const dot = document.createElement('button');\n      dot.classList.add('carousel-dot');\n      if (i === 0) dot.classList.add('active');\n      dot.onclick = () => goToSlide(i);\n      dotsContainer.appendChild(dot);\n    }\n  }\n\n  function updateDots() {\n    const dots = document.querySelectorAll('.carousel-dot');\n    dots.forEach((dot, i) => {\n      dot.classList.toggle('active', i === Math.floor(currentIndex / videosPerView));\n    });\n  }\n\n  function goToSlide(index) {\n    currentIndex = index * videosPerView;\n    applyTransform();\n    updateDots();\n  }\n\n  function applyTransform() {\n    const scrollLeft = currentIndex * (280 + 20);\n    const carousel = document.getElementById('videoCarousel');\n    carousel.style.transition = 'transform 0.4s ease';\n    carousel.style.transform = `translateX(-${scrollLeft}px)`;\n  }\n\n  function moveCarousel(direction) {\n    const maxIndex = totalVideos - videosPerView;\n    currentIndex = Math.max(0, Math.min(currentIndex + 1 * direction, maxIndex));\n    applyTransform();\n    updateDots();\n  }\n\n  function togglePlayPause(videoElement) {\n    if (videoElement.paused) {\n      const videos = document.querySelectorAll('.grid-video');\n      videos.forEach(video => {\n        if (video !== videoElement) {\n          video.pause();\n          video.muted = true;\n        }\n      });\n      videoElement.muted = false;\n      videoElement.play();\n    } else {\n      videoElement.pause();\n    }\n  }\n\n  generateDots();\n</script>",
