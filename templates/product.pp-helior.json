        "liquid": "{% comment %}\n  Compte à rebours jusqu'à minuit - Version Française\n{% endcomment %}\n<style>\n  .promo-announcement-bar {\n    background: #ffffff;\n    text-align: center;\n    padding: 10px 16px;\n    font-family: inherit;\n    width: 100%;\n    box-sizing: border-box;\n    border: 1px solid #e8e8e8;\n    border-radius: 6px;\n  }\n  .promo-announcement-bar__top-text {\n    font-size: 10px;\n    font-weight: 700;\n    letter-spacing: 0.1em;\n    text-transform: uppercase;\n    margin-bottom: 6px;\n    color: #223547;\n  }\n  .promo-announcement-bar__timer-wrap {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    gap: 5px;\n  }\n  .promo-timer__block {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n  }\n  .promo-timer__number {\n    background: #223547;\n    color: #ffffff;\n    font-size: 14px;\n    font-weight: 700;\n    line-height: 1;\n    padding: 4px 8px;\n    min-width: 30px;\n    text-align: center;\n    border-radius: 3px;\n    letter-spacing: 0.02em;\n    font-variant-numeric: tabular-nums;\n  }\n  .promo-timer__label {\n    font-size: 8px;\n    font-weight: 500;\n    letter-spacing: 0.08em;\n    text-transform: uppercase;\n    color: #999;\n    margin-top: 2px;\n  }\n  .promo-timer__separator {\n    font-size: 14px;\n    font-weight: 700;\n    color: #223547;\n    line-height: 1;\n    margin-bottom: 10px;\n    align-self: flex-start;\n    padding-top: 3px;\n  }\n</style>\n\n<div class=\"promo-announcement-bar\">\n  <div class=\"promo-announcement-bar__top-text\">\n    Notre Plus Grosse Promo de l'Année\n  </div>\n  <div class=\"promo-announcement-bar__timer-wrap\">\n    <div class=\"promo-timer__block\">\n      <span class=\"promo-timer__number\" id=\"promo-hours\">00</span>\n      <span class=\"promo-timer__label\">Heures</span>\n    </div>\n    <div class=\"promo-timer__separator\">:</div>\n    <div class=\"promo-timer__block\">\n      <span class=\"promo-timer__number\" id=\"promo-minutes\">00</span>\n      <span class=\"promo-timer__label\">Min</span>\n    </div>\n    <div class=\"promo-timer__separator\">:</div>\n    <div class=\"promo-timer__block\">\n      <span class=\"promo-timer__number\" id=\"promo-seconds\">00</span>\n      <span class=\"promo-timer__label\">Sec</span>\n    </div>\n  </div>\n</div>\n\n<script>\n  (function () {\n    function pad(n) { return String(n).padStart(2, '0'); }\n    function updateCountdown() {\n      var now = new Date();\n      var midnight = new Date();\n      midnight.setHours(24, 0, 0, 0);\n      var diff = Math.floor((midnight - now) / 1000);\n      if (diff < 0) diff = 0;\n      document.getElementById('promo-hours').textContent   = pad(Math.floor(diff / 3600));\n      document.getElementById('promo-minutes').textContent = pad(Math.floor((diff % 3600) / 60));\n      document.getElementById('promo-seconds').textContent = pad(diff % 60);\n    }\n    updateCountdown();\n    setInterval(updateCountdown, 1000);\n  })();\n</script>",
