            "liquid": "<style>\n  .vmdr-section {\n    background: linear-gradient(175deg, #060b14 0%, #0d1b2e 50%, #0a1525 100%);\n    position: relative;\n    padding: 56px 0 64px;\n    overflow: hidden;\n    font-family: Arial, Helvetica, sans-serif;\n  }\n\n  .vmdr-section::before {\n    content: '';\n    position: absolute;\n    inset: 0;\n    background:\n      radial-gradient(ellipse 80% 40% at 50% 0%, rgba(120,160,210,0.07) 0%, transparent 55%),\n      repeating-linear-gradient(90deg, transparent, transparent 80px, rgba(255,255,255,0.008) 80px, rgba(255,255,255,0.008) 81px);\n    pointer-events: none;\n    z-index: 0;\n  }\n\n  .vmdr-section::after {\n    content: '';\n    position: absolute;\n    top: 0; left: 0; right: 0; height: 1px;\n    background: linear-gradient(90deg, transparent, rgba(160,200,240,0.35), transparent);\n    z-index: 1;\n  }\n\n  .vmdr-inner {\n    position: relative;\n    z-index: 2;\n    padding: 0 20px;\n    max-width: 100%;\n  }\n\n  /* ── TITRE ── */\n  .vmdr-title {\n    text-align: center;\n    font-family: Georgia, 'Times New Roman', serif;\n    font-size: clamp(22px, 4.5vw, 42px);\n    font-weight: 400;\n    color: #eef4fa;\n    line-height: 1.25;\n    margin: 0 auto 28px;\n    max-width: 680px;\n    text-shadow: 0 2px 20px rgba(0,0,0,0.5);\n  }\n\n  .vmdr-title strong {\n    font-weight: 900;\n    color: #fff;\n  }\n\n  /* ── STATS BAR ── */\n  .vmdr-stats {\n    display: flex;\n    justify-content: center;\n    gap: 0;\n    background: rgba(255,255,255,0.05);\n    border: 1px solid rgba(140,180,230,0.15);\n    border-radius: 12px;\n    padding: 18px 10px;\n    margin: 0 auto 40px;\n    max-width: 600px;\n    backdrop-filter: blur(4px);\n  }\n\n  .vmdr-stat {\n    flex: 1;\n    text-align: center;\n    padding: 0 12px;\n    border-right: 1px solid rgba(140,180,230,0.15);\n  }\n\n  .vmdr-stat:last-child { border-right: none; }\n\n  .vmdr-stat-num {\n    font-family: Georgia, serif;\n    font-size: clamp(20px, 4vw, 30px);\n    font-weight: 900;\n    color: #fff;\n    line-height: 1;\n    margin-bottom: 6px;\n  }\n\n  .vmdr-stat-label {\n    font-size: 11px;\n    color: #7a9abf;\n    line-height: 1.3;\n    font-weight: 500;\n  }\n\n  /* ── CAROUSEL WRAPPER ── */\n  .vmdr-carousel-wrap {\n    position: relative;\n    overflow: hidden;\n    margin: 0 -20px;\n    padding: 0 20px;\n  }\n\n  .vmdr-carousel-wrap::after {\n    content: '';\n    position: absolute;\n    top: 0; right: 0; bottom: 0;\n    width: 60px;\n    background: linear-gradient(270deg, #060b14 0%, transparent 100%);\n    pointer-events: none;\n    z-index: 5;\n  }\n\n  .vmdr-carousel {\n    display: flex;\n    gap: 16px;\n    overflow-x: auto;\n    scroll-snap-type: x mandatory;\n    -webkit-overflow-scrolling: touch;\n    scrollbar-width: none;\n    padding: 8px 0 16px;\n    cursor: grab;\n  }\n\n  .vmdr-carousel::-webkit-scrollbar { display: none; }\n  .vmdr-carousel:active { cursor: grabbing; }\n\n  /* ── CARD ── */\n  .vmdr-card {\n    min-width: 280px;\n    width: 280px;\n    background: #ffffff;\n    border-radius: 18px;\n    overflow: hidden;\n    flex-shrink: 0;\n    scroll-snap-align: start;\n    box-shadow: 0 8px 32px rgba(0,0,0,0.4), 0 0 0 1px rgba(26,74,138,0.1);\n  }\n\n  /* ── VIDEO PLACEHOLDER ── */\n  .vmdr-video {\n    width: 100%;\n    aspect-ratio: 3/4;\n    background: linear-gradient(145deg, #0d1b2e 0%, #1a3a6a 50%, #0d1b2e 100%);\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    position: relative;\n    overflow: hidden;\n  }\n\n  /* Si URL image fournie */\n  .vmdr-video img {\n    width: 100%;\n    height: 100%;\n    object-fit: cover;\n    display: block;\n  }\n\n  .vmdr-play {\n    position: absolute;\n    top: 50%; left: 50%;\n    transform: translate(-50%, -50%);\n    width: 56px; height: 56px;\n    background: rgba(255,255,255,0.92);\n    border-radius: 50%;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    box-shadow: 0 4px 20px rgba(0,0,0,0.3);\n    z-index: 2;\n  }\n\n  .vmdr-play::after {\n    content: '';\n    width: 0; height: 0;\n    border-top: 10px solid transparent;\n    border-bottom: 10px solid transparent;\n    border-left: 18px solid #0a1220;\n    margin-left: 3px;\n  }\n\n  .vmdr-url-hint {\n    position: absolute;\n    bottom: 12px; left: 0; right: 0;\n    text-align: center;\n    font-size: 10px;\n    font-weight: 700;\n    letter-spacing: 1.5px;\n    text-transform: uppercase;\n    color: rgba(255,255,255,0.25);\n  }\n\n  /* ── CARD BODY ── */\n  .vmdr-card-body {\n    padding: 16px 18px 20px;\n    background: #fff;\n  }\n\n  .vmdr-badge-row {\n    display: flex;\n    align-items: center;\n    gap: 10px;\n    margin-bottom: 10px;\n  }\n\n  .vmdr-badge {\n    display: inline-flex;\n    align-items: center;\n    gap: 5px;\n    background: #0a1220;\n    color: #fff;\n    font-size: 10px;\n    font-weight: 700;\n    letter-spacing: 0.8px;\n    text-transform: uppercase;\n    padding: 5px 10px;\n    border-radius: 20px;\n  }\n\n  .vmdr-badge-icon { font-size: 11px; }\n\n  .vmdr-badge-sub {\n    font-size: 13px;\n    color: #555;\n    font-weight: 500;\n  }\n\n  .vmdr-card-name {\n    font-size: 17px;\n    font-weight: 800;\n    color: #0a1220;\n    margin-bottom: 3px;\n  }\n\n  .vmdr-card-exp {\n    font-size: 13px;\n    color: #8a9ab0;\n    margin-bottom: 12px;\n  }\n\n  .vmdr-card-quote {\n    font-size: 14px;\n    color: #333;\n    line-height: 1.6;\n    border-left: 2px solid #0d1b2e;\n    padding-left: 12px;\n  }\n\n  /* ── DOTS ── */\n  .vmdr-dots {\n    display: flex;\n    justify-content: center;\n    gap: 6px;\n    margin-top: 20px;\n  }\n\n  .vmdr-dot {\n    width: 6px; height: 6px;\n    border-radius: 50%;\n    background: rgba(255,255,255,0.2);\n    transition: all 0.3s;\n    cursor: pointer;\n  }\n\n  .vmdr-dot.active {\n    background: #fff;\n    width: 20px;\n    border-radius: 3px;\n  }\n</style>\n\n<div class=\"vmdr-section\">\n  <div class=\"vmdr-inner\">\n\n    <!-- TITRE -->\n    <p class=\"vmdr-title\">\n      <strong>Recommandé</strong> par plus de<br>\n      <strong>500 spécialistes</strong> à travers le monde\n    </p>\n\n    <!-- STATS -->\n    <div class=\"vmdr-stats\">\n      <div class=\"vmdr-stat\">\n        <div class=\"vmdr-stat-num\">5 ans</div>\n        <div class=\"vmdr-stat-label\">de tests<br>cliniques</div>\n      </div>\n      <div class=\"vmdr-stat\">\n        <div class=\"vmdr-stat-num\">1 748</div>\n        <div class=\"vmdr-stat-label\">patients<br>suivis</div>\n      </div>\n      <div class=\"vmdr-stat\">\n        <div class=\"vmdr-stat-num\">0</div>\n        <div class=\"vmdr-stat-label\">effet secondaire<br>reporté</div>\n      </div>\n    </div>\n\n    <!-- CAROUSEL -->\n    <div class=\"vmdr-carousel-wrap\">\n      <div class=\"vmdr-carousel\" id=\"vmdrCarousel\">\n\n        <!-- CARTE 1 — MÉDECIN UROLOGUE -->\n        <div class=\"vmdr-card\">\n          <div class=\"vmdr-video\">\n            <img src=\"METTRE_URL_VIDEO_THUMBNAIL_1\" alt=\"\" onerror=\"this.style.display='none'\">\n            <div class=\"vmdr-play\"></div>\n            <div class=\"vmdr-url-hint\">Mettre URL vidéo ici</div>\n          </div>\n          <div class=\"vmdr-card-body\">\n            <div class=\"vmdr-badge-row\">\n              <span class=\"vmdr-badge\"><span class=\"vmdr-badge-icon\">⚕️</span> Médecin</span>\n              <span class=\"vmdr-badge-sub\">Spécialiste en urologie</span>\n            </div>\n            <div class=\"vmdr-card-name\">Dr. Laurent Moreau</div>\n            <div class=\"vmdr-card-exp\">22 ans d'expérience</div>\n            <div class=\"vmdr-card-quote\">En 22 ans de cabinet, j'ai vu beaucoup d'hommes souffrir en silence. VigorMax™ est la première solution que je recommande sans hésiter : action rapide, zéro contre-indication cardiaque, et des résultats que mes patients confirment.</div>\n          </div>\n        </div>\n\n        <!-- CARTE 2 — SEXOLOGUE -->\n        <div class=\"vmdr-card\">\n          <div class=\"vmdr-video\">\n            <img src=\"METTRE_URL_VIDEO_THUMBNAIL_2\" alt=\"\" onerror=\"this.style.display='none'\">\n            <div class=\"vmdr-play\"></div>\n            <div class=\"vmdr-url-hint\">Mettre URL vidéo ici</div>\n          </div>\n          <div class=\"vmdr-card-body\">\n            <div class=\"vmdr-badge-row\">\n              <span class=\"vmdr-badge\"><span class=\"vmdr-badge-icon\">💬</span> Sexologue</span>\n              <span class=\"vmdr-badge-sub\">Spécialiste du couple</span>\n            </div>\n            <div class=\"vmdr-card-name\">Dr. Claire Vasseur</div>\n            <div class=\"vmdr-card-exp\">15 ans d'expérience</div>\n            <div class=\"vmdr-card-quote\">80% des hommes qui me consultent souffrent avant tout d'anxiété de performance. VigorMax™ casse ce cercle vicieux : il agit vite, sans attente, et redonne cette confiance qui change tout dans le couple.</div>\n          </div>\n        </div>\n\n        <!-- CARTE 3 — CLIENTE -->\n        <div class=\"vmdr-card\">\n          <div class=\"vmdr-video\">\n            <img src=\"METTRE_URL_VIDEO_THUMBNAIL_3\" alt=\"\" onerror=\"this.style.display='none'\">\n            <div class=\"vmdr-play\"></div>\n            <div class=\"vmdr-url-hint\">Mettre URL vidéo ici</div>\n          </div>\n          <div class=\"vmdr-card-body\">\n            <div class=\"vmdr-badge-row\">\n              <span class=\"vmdr-badge\" style=\"background:#27ae60;\"><span class=\"vmdr-badge-icon\">✓</span> Cliente</span>\n              <span class=\"vmdr-badge-sub\">Achat vérifié</span>\n            </div>\n            <div class=\"vmdr-card-name\">Sophie M.</div>\n            <div class=\"vmdr-card-exp\">Mariée depuis 28 ans</div>\n            <div class=\"vmdr-card-quote\">Je l'ai commandé pour mon mari un peu en cachette, je ne lui ai rien dit. Trois semaines plus tard, il avait retrouvé son regard d'avant. Le nôtre aussi, par la même occasion.</div>\n          </div>\n        </div>\n\n      </div>\n    </div>\n\n    <!-- DOTS -->\n    <div class=\"vmdr-dots\" id=\"vmdrDots\">\n      <div class=\"vmdr-dot active\" onclick=\"vmdrGoTo(0)\"></div>\n      <div class=\"vmdr-dot\" onclick=\"vmdrGoTo(1)\"></div>\n      <div class=\"vmdr-dot\" onclick=\"vmdrGoTo(2)\"></div>\n    </div>\n\n  </div>\n</div>\n\n<script>\n  const vmdrC = document.getElementById('vmdrCarousel');\n  const vmdrD = document.querySelectorAll('.vmdr-dot');\n\n  vmdrC.addEventListener('scroll', () => {\n    const index = Math.round(vmdrC.scrollLeft / 296);\n    vmdrD.forEach((d, i) => d.classList.toggle('active', i === index));\n  });\n\n  function vmdrGoTo(i) {\n    vmdrC.scrollTo({ left: i * 296, behavior: 'smooth' });\n  }\n</script>"
